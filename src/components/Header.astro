---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2>
			<a href="/" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-weight: 700; font-size: 1.25rem;">
				<span style="background-color: #0f172a; color: #ef4444; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.95rem; display: inline-flex; align-items: center; font-weight: 900;">&gt;_</span>
				<span style="color: #1e293b;">Error</span><span style="color: #ef4444;">Ledger</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		display: flex;
		align-items: center;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 1rem 0;
	}
	.internal-links a {
		padding: 0.5rem 1rem;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.internal-links a.active {
		text-decoration: none;
		border-bottom-color: rgb(var(--accent));
	}
</style>