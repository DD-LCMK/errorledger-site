---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
	<head>
		<BaseHead title="Base64 Encoder / Decoder | ErrorLedger" description="Encode text to Base64 strings or decode Base64 back to plain text instantly and securely client-side." />
		<style>
			main { width: 720px; max-width: calc(100% - 2rem); margin: 0 auto; padding: 3em 1rem; }
			h1 { font-size: 2.25rem; margin-bottom: 0.5rem; color: #1a202c; }
			p.subtitle { color: #475569; margin-bottom: 2rem; }
			
			.tool-box { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1.75rem; margin-bottom: 2rem; }
			
			.input-group { margin-bottom: 1.5rem; }
			label { display: block; font-size: 0.9rem; font-weight: 600; color: #334155; margin-bottom: 0.5rem; }
			textarea { width: 100%; height: 120px; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px; font-family: monospace; font-size: 0.95rem; outline: none; background: #ffffff; color: #1e293b; resize: vertical; }
			textarea:focus { border-color: #ef4444; }
			
			.action-row { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
			button { background: #0f172a; color: white; border: none; padding: 0.65rem 1.25rem; border-radius: 6px; font-weight: 600; cursor: pointer; }
			button:hover { background: #ef4444; }
			.btn-secondary { background: #64748b; }
			.btn-secondary:hover { background: #475569; }

			.error-display { background: #fef2f2; border: 1px solid #fee2e2; color: #b91c1c; border-radius: 6px; padding: 0.75rem; margin-bottom: 1.5rem; display: none; font-size: 0.9rem; }

			/* Dark Mode */
			:global(html.dark) h1 { color: #f8fafc; }
			:global(html.dark) .tool-box { background: #1e293b; border-color: #334155; }
			:global(html.dark) label { color: #cbd5e1; }
			:global(html.dark) textarea { background: #0f172a; border-color: #334155; color: #f8fafc; }
			:global(html.dark) button { background: #334155; }
			:global(html.dark) button:hover { background: #ef4444; }
			:global(html.dark) .btn-secondary { background: #475569; }
			:global(html.dark) .btn-secondary:hover { background: #334155; }
			:global(html.dark) .error-display { background: #451a03; border-color: #78350f; color: #fef3c7; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Base64 Encoder / Decoder</h1>
			<p class="subtitle">Convert plain text into Base64 format strings or safely parse Base64 back to readable text.</p>

			<div class="tool-box">
				<div class="input-group">
					<label for="input-text">Input Data</label>
					<textarea id="input-text" placeholder="Type plain text or paste Base64 data here..."></textarea>
				</div>

				<div class="action-row">
					<button id="btn-encode">🔒 Encode to Base64</button>
					<button id="btn-decode" class="btn-secondary">🔓 Decode Base64</button>
				</div>

				<div class="error-display" id="converter-error"></div>

				<div class="input-group">
					<label for="output-text">Output Result</label>
					<textarea id="output-text" placeholder="Result will appear here..." readonly></textarea>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			const inputArea = document.getElementById('input-text') as HTMLTextAreaElement;
			const outputArea = document.getElementById('output-text') as HTMLTextAreaElement;
			const errorDiv = document.getElementById('converter-error');

			function showError(msg: string) {
				if (!errorDiv) return;
				errorDiv.textContent = msg;
				errorDiv.style.display = 'block';
			}

			function clearError() {
				if (errorDiv) errorDiv.style.display = 'none';
			}

			// Safe UTF-8 encoding (prevents crashes with emojis/special characters)
			document.getElementById('btn-encode')?.addEventListener('click', () => {
				clearError();
				const rawText = inputArea.value;
				if (!rawText) {
					outputArea.value = '';
					return;
				}
				try {
					const bytes = new TextEncoder().encode(rawText);
					const binString = Array.from(bytes, (byte) => String.fromCharCode(byte)).join('');
					outputArea.value = btoa(binString);
				} catch (e) {
					showError('❌ Failed to encode text to Base64.');
				}
			});

			// Safe UTF-8 decoding
			document.getElementById('btn-decode')?.addEventListener('click', () => {
				clearError();
				const base64Text = inputArea.value.trim();
				if (!base64Text) {
					outputArea.value = '';
					return;
				}
				try {
					const binString = atob(base64Text);
					const bytes = Uint8Array.from(binString, (m) => m.charCodeAt(0));
					outputArea.value = new TextDecoder().decode(bytes);
				} catch (e) {
					showError('❌ Invalid Base64 string format. Please verify your input data contains no illegal characters.');
					outputArea.value = '';
				}
			});
		</script>
	</body>
</html>